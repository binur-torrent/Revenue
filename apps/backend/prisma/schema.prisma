
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @db.Decimal(12, 2)
  stock     Int      @default(0)
  category  String?
}

datasource db {
  provider = "postgresql"
}


